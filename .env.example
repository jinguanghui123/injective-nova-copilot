# ─────────────────────────────────────────────────────────────────
# Nova Copilot — environment template
# Copy to `.env` and fill in. NEVER commit the real `.env`.
# ─────────────────────────────────────────────────────────────────

# Injective network: "testnet" or "mainnet"
INJ_NETWORK=testnet

# Wallet mnemonic (12 or 24 words). This signs transactions.
# Generate one with any EVM/Cosmos-compatible wallet tool.
# Fund testnet wallets from the Injective faucet.
INJ_MNEMONIC=

# Injective MCP server endpoint (the official trading/identity tool layer).
# Local mode: run InjectiveLabs/mcp-server and point at its stdio/HTTP bridge.
# Remote mode: hosted endpoint, if available.
INJ_MCP_SERVER_URL=

# Injective chain RPC (for read-only simulation / queries)
INJ_RPC_URL=https://sentry.lcd.injective.network:443

# ─── Optional: agent identity (ERC-8004) ─────────────────────────
# Pinata JWT for pinning the agent card to IPFS during registration.
PINATA_JWT=

# ─── Optional: LLM provider ──────────────────────────────────────
# ollama = local (default, free, private); openai / anthropic = cloud
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:latest
OLLAMA_HOST=http://localhost:11434
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
