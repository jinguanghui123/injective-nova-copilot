# ─────────────────────────────────────────────────────────────────
# Nova Copilot — environment template
# Copy to `.env` and fill in. NEVER commit the real `.env`.
# ─────────────────────────────────────────────────────────────────

# Injective network: "testnet" or "mainnet"
INJECTIVE_NETWORK=testnet

# Wallet PRIVATE KEY in hex (NOT a mnemonic, NOT the address).
# Generate one: `uv run python scripts/new_key.py`
# Fund testnet wallets from the Injective faucet:
#   https://injective-hub.vercel.app/bridge / https://testnet.injective.network/
# This signs transactions. NEVER log it, NEVER commit it.
INJECTIVE_PRIVATE_KEY=

# ─── Optional: LLM provider ──────────────────────────────────────
# ollama = local (default, free, private); openai / anthropic = cloud
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:latest
OLLAMA_HOST=http://localhost:11434
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ─── Optional: agent identity (ERC-8004, week 3) ─────────────────
# Pinata JWT for pinning the agent card to IPFS during registration.
# PINATA_JWT=
